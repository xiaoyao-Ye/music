{
  "name": "Music",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "description": "A music application",
  "author": "_Ghosteye <Ghosteye@yeah.net>",
  "license": "MIT",
  "keywords": [
    "music",
    "electron"
  ],
  "main": "dist-electron/main/index.js",
  "debug": {
    "env": {
      "VITE_DEV_SERVER_URL": "http://127.0.0.1:3344/"
    }
  },
  "scripts": {
    "build": "vue-tsc --noEmit && vite build && electron-builder",
    "dev": "vite",
    "lint": "eslint .",
    "typecheck": "vue-tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest run",
    "up": "taze major -I",
    "postinstall": "npx simple-git-hooks"
  },
  "dependencies": {
    "@vueuse/core": "^12.0.0",
    "better-sqlite3": "^11.7.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-store": "^10.0.0",
    "lucide-vue-next": "^0.468.0",
    "music-metadata": "^10.6.4",
    "pinia": "^2.3.0",
    "radix-vue": "^1.9.13",
    "reflect-metadata": "^0.2.2",
    "sharp": "^0.33.5",
    "tailwind-merge": "^2.5.5",
    "typeorm": "^0.3.20",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^3.12.0",
    "@iconify-json/carbon": "^1.2.5",
    "@iconify-json/game-icons": "^1.2.1",
    "@radix-icons/vue": "^1.0.0",
    "@types/node": "^22.10.2",
    "@unocss/eslint-config": "^0.65.1",
    "@unocss/eslint-plugin": "^0.65.1",
    "@unocss/reset": "^0.65.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue-macros/volar": "^0.30.8",
    "@vue/test-utils": "^2.4.6",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9.17.0",
    "eslint-plugin-format": "^0.1.3",
    "jsdom": "^25.0.1",
    "lint-staged": "^15.2.11",
    "pnpm": "^9.15.0",
    "simple-git-hooks": "^2.11.1",
    "taze": "^0.18.0",
    "typescript": "~5.6.3",
    "unocss": "^0.65.1",
    "unocss-preset-animations": "^1.1.0",
    "unocss-preset-shadcn": "^0.3.1",
    "unplugin-auto-import": "^0.19.0",
    "unplugin-vue-components": "^0.28.0",
    "unplugin-vue-macros": "^2.13.6",
    "unplugin-vue-router": "^0.10.9",
    "vite": "^6.0.3",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^2.1.8",
    "vue-tsc": "^2.1.10"
  },
  "resolutions": {
    "vite": "^6.0.3"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
